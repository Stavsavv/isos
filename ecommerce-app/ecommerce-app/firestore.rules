rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // PRODUCTS — only admins can modify
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();

      // REVIEWS — users can create/edit their own
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin()
          || (signedIn() && resource.data.userId == request.auth.uid);
      }
    }

    // ORDERS — users can see their own, admins see all
    match /orders/{id} {
      allow read: if isAdmin()
        || (signedIn() && request.auth.uid == resource.data.userId);
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.paymentStatus == 'pending'
        && request.resource.data.orderStatus == 'processing'
        && request.resource.data.totalPrice == 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0;
      allow update: if isAdmin()
        || (signedIn()
          && request.auth.uid == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['shippingAddress', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // USERS — users can see/edit their own, admins can read/update all
    match /users/{id} {
      allow read: if isAdmin() || isOwner(id);
      allow create: if isOwner(id);
      allow update: if isAdmin()
        || (isOwner(id)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'photoURL', 'phone', 'address', 'updatedAt']));
    }

    // CARTS — each user can only access their own cart
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // COUPONS — read-only for users, admin write
    match /coupons/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // WISHLIST — each user can only access their own items
    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);

      match /items/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ANALYTICS (admin only)
    match /analytics/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
